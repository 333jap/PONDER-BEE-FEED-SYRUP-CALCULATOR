<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Syrup Calculator</title>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400&display=swap" rel="stylesheet">

<style>
:root{
    --label:#6f6f6f;
    --line:#a0a0a0;
    --input-bg:#e4ecec;
    --border:#666;
}

*{
    box-sizing:border-box;
    margin:0;
    padding:0;
}

body{
    font-family:'Montserrat',sans-serif;
    background:#ffffff;
    color:#000;
}

.container{
    max-width:900px;
    margin:0 auto;
    padding:40px 25px 80px;
}

.ratio-group{
    display:flex;
    justify-content:center;
    gap:120px;
    margin-bottom:60px;
}

.ratio-option{
    display:flex;
    align-items:center;
    gap:18px;
    cursor:pointer;
    font-size:64px;
    font-weight:300;
}

.ratio-option input{
    width:34px;
    height:34px;
    transform:scale(1.5);
}

.section{
    text-align:center;
    margin-bottom:65px;
}

.label{
    color:var(--label);
    font-size:64px;
    font-weight:300;
    margin-bottom:24px;
}

.calc-input{
    width:100%;
    height:140px;
    background:var(--input-bg);
    border:6px solid var(--border);
    text-align:center;
    font-size:72px;
    font-family:'Montserrat',sans-serif;
    font-weight:300;
    outline:none;
}

@media (max-width:768px){

    .ratio-group{
        gap:60px;
    }

    .ratio-option{
        font-size:38px;
    }

    .label{
        font-size:34px;
    }

    .calc-input{
        height:90px;
        font-size:48px;
        border-width:4px;
    }
}
</style>

</head>
<body>

<div class="container">

    <div class="ratio-group">

        <label class="ratio-option">
            <input type="radio" name="ratio" value="1" checked>
            <span>1:1</span>
        </label>

        <label class="ratio-option">
            <input type="radio" name="ratio" value="2">
            <span>2:1</span>
        </label>

    </div>

    <div class="section">
        <div class="label">Pounds of Sugar</div>
        <input id="sugar" class="calc-input" type="number" step="any">
    </div>

    <div class="section">
        <div class="label">Gallons of Water</div>
        <input id="water" class="calc-input" type="number" step="any">
    </div>

    <div class="section">
        <div class="label">Gallons of Syrup</div>
        <input id="syrup" class="calc-input" type="number" step="any">
    </div>

</div>

<script>

const ratios = {
    1: {
        sugarPerWater: 8.347,
        syrupPerSugar: 0.19363
    },
    2: {
        sugarPerWater: 16.6945,
        syrupPerSugar: 0.13528
    }
};

const sugar = document.getElementById("sugar");
const water = document.getElementById("water");
const syrup = document.getElementById("syrup");

let updating = false;

function currentRatio() {
    return ratios[
        document.querySelector(
            'input[name="ratio"]:checked'
        ).value
    ];
}

function round(num) {
    return Number(num).toFixed(2);
}

function clearAll() {
    sugar.value = "";
    water.value = "";
    syrup.value = "";
}

function updateFromSugar() {

    if (updating) return;

    if (sugar.value === "") {
        water.value = "";
        syrup.value = "";
        return;
    }

    updating = true;

    const s = parseFloat(sugar.value);
    const r = currentRatio();

    water.value = round(
        s / r.sugarPerWater
    );

    syrup.value = round(
        s * r.syrupPerSugar
    );

    updating = false;
}

function updateFromWater() {

    if (updating) return;

    if (water.value === "") {
        sugar.value = "";
        syrup.value = "";
        return;
    }

    updating = true;

    const w = parseFloat(water.value);
    const r = currentRatio();

    const s = w * r.sugarPerWater;

    sugar.value = round(s);

    syrup.value = round(
        s * r.syrupPerSugar
    );

    updating = false;
}

function updateFromSyrup() {

    if (updating) return;

    if (syrup.value === "") {
        sugar.value = "";
        water.value = "";
        return;
    }

    updating = true;

    const sy = parseFloat(syrup.value);
    const r = currentRatio();

    const s = sy / r.syrupPerSugar;

    sugar.value = round(s);

    water.value = round(
        s / r.sugarPerWater
    );

    updating = false;
}

sugar.addEventListener("input", updateFromSugar);
water.addEventListener("input", updateFromWater);
syrup.addEventListener("input", updateFromSyrup);

document
.querySelectorAll('input[name="ratio"]')
.forEach(radio => {

    radio.addEventListener("change", () => {

        clearAll();

    });

});

</script>

</body>
</html>
